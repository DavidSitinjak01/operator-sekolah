generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Siswa {
  id               String   @id @default(cuid())
  no               String
  nama             String
  nipd             String   @default("")
  jenisKelamin     String   @default("")
  nisn             String   @default("")
  tempatLahir      String   @default("")
  tanggalLahir     String   @default("")
  nik              String   @default("")
  agama            String   @default("")
  alamat           String   @default("")
  hp               String   @default("")
  email            String   @default("")
  rombel           String   @default("")
  kebutuhanKhusus  String   @default("")
  sekolahAsal      String   @default("")
  namaAyah         String   @default("")
  namaIbu          String   @default("")
  namaWali         String   @default("")
  status           String   @default("Aktif")
  tahunPelajaran   String   @default("2025/2026")
  semester         String   @default("Ganjil")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tahunPelajaran, semester])
  @@index([rombel])
}

model Guru {
  id                 String   @id @default(cuid())
  no                 String
  nama               String
  nuptk              String   @default("")
  jenisKelamin       String   @default("")
  tempatLahir        String   @default("")
  tanggalLahir       String   @default("")
  nip                String   @default("")
  statusKepegawaian  String   @default("")
  jenisPTK           String   @default("")
  agama              String   @default("")
  alamat             String   @default("")
  hp                 String   @default("")
  email              String   @default("")
  tugasTambahan      String   @default("")
  pangkatGolongan    String   @default("")
  sumberGaji         String   @default("")
  statusPerkawinan   String   @default("")
  kewarganegaraan    String   @default("")
  status             String   @default("Aktif")
  tahunPelajaran     String   @default("2025/2026")
  semester           String   @default("Ganjil")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tahunPelajaran, semester])
  @@unique([no, tahunPelajaran, semester])
}

model MutasiMasuk {
  id              String   @id @default(cuid())
  nama            String
  nis             String
  asalSekolah     String
  kelas           String
  tanggalMasuk    String
  alasan          String
  noSurat         String
  tahunPelajaran  String   @default("2025/2026")
  semester        String   @default("Ganjil")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MutasiKeluar {
  id               String   @id @default(cuid())
  nama             String
  nis              String
  tujuanSekolah    String
  kelas            String
  tanggalKeluar    String
  alasan           String
  noSurat          String
  tahunPelajaran   String   @default("2025/2026")
  semester         String   @default("Ganjil")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}