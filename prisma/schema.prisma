generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("operator")
  nama      String   @default("")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Siswa {
  id                      String   @id @default(cuid())
  no                      String
  nama                    String
  nipd                    String   @default("")
  jenisKelamin            String   @default("")
  nisn                    String   @default("")
  tempatLahir             String   @default("")
  tanggalLahir            String   @default("")
  nik                     String   @default("")
  agama                   String   @default("")
  alamat                  String   @default("")
  rt                      String   @default("")
  rw                      String   @default("")
  dusun                   String   @default("")
  kelurahan               String   @default("")
  kecamatan               String   @default("")
  kodePos                 String   @default("")
  jenisTinggal            String   @default("")
  alatTransportasi        String   @default("")
  telepon                 String   @default("")
  hp                      String   @default("")
  email                   String   @default("")
  skhun                   String   @default("")
  penerimaKPS             String   @default("")
  noKPS                   String   @default("")
  namaAyah                String   @default("")
  ayahTahunLahir          String   @default("")
  ayahJenjangPendidikan   String   @default("")
  ayahPekerjaan           String   @default("")
  ayahPenghasilan         String   @default("")
  ayahNik                 String   @default("")
  namaIbu                 String   @default("")
  ibuTahunLahir           String   @default("")
  ibuJenjangPendidikan    String   @default("")
  ibuPekerjaan            String   @default("")
  ibuPenghasilan          String   @default("")
  ibuNik                  String   @default("")
  namaWali                String   @default("")
  waliTahunLahir          String   @default("")
  waliJenjangPendidikan   String   @default("")
  waliPekerjaan           String   @default("")
  waliPenghasilan         String   @default("")
  waliNik                 String   @default("")
  rombel                  String   @default("")
  noPesertaUN             String   @default("")
  noSeriIjazah            String   @default("")
  penerimaKIP             String   @default("")
  nomorKIP                String   @default("")
  namaKIP                 String   @default("")
  nomorKKS                String   @default("")
  noRegAktaLahir          String   @default("")
  bank                    String   @default("")
  nomorRekeningBank       String   @default("")
  rekeningAtasNama        String   @default("")
  layakPIP                String   @default("")
  alasanLayakPIP          String   @default("")
  kebutuhanKhusus         String   @default("")
  sekolahAsal             String   @default("")
  anakKeBerapa            String   @default("")
  lintang                 String   @default("")
  bujur                   String   @default("")
  noKK                    String   @default("")
  beratBadan              String   @default("")
  tinggiBadan             String   @default("")
  lingkarKepala           String   @default("")
  jmlSaudaraKandung       String   @default("")
  jarakRumahKeSekolah     String   @default("")
  status                  String   @default("Aktif")
  tahunPelajaran          String   @default("2025/2026")
  semester                String   @default("Ganjil")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([tahunPelajaran, semester])
  @@index([rombel])

  mutasiKeluar MutasiKeluar[]
}

model Guru {
  id                       String   @id @default(cuid())
  no                       String
  nama                     String
  nuptk                    String   @default("")
  jenisKelamin             String   @default("")
  tempatLahir              String   @default("")
  tanggalLahir             String   @default("")
  nip                      String   @default("")
  statusKepegawaian        String   @default("")
  jenisPTK                 String   @default("")
  agama                    String   @default("")
  alamat                   String   @default("")
  rt                       String   @default("")
  rw                       String   @default("")
  namaDusun                String   @default("")
  desaKelurahan            String   @default("")
  kecamatan                String   @default("")
  kodePos                  String   @default("")
  telepon                  String   @default("")
  hp                       String   @default("")
  email                    String   @default("")
  tugasTambahan            String   @default("")
  skCPNS                   String   @default("")
  tanggalCPNS              String   @default("")
  skPengangkatan           String   @default("")
  tmtPengangkatan          String   @default("")
  lembagaPengangkatan      String   @default("")
  pangkatGolongan          String   @default("")
  sumberGaji               String   @default("")
  namaIbuKandung           String   @default("")
  statusPerkawinan         String   @default("")
  namaSuamiIstri           String   @default("")
  nipSuamiIstri            String   @default("")
  pekerjaanSuamiIstri      String   @default("")
  tmtPNS                   String   @default("")
  sudahLisensiKepsek       String   @default("")
  pernahDiklatKepengawasan String   @default("")
  keahlianBraille          String   @default("")
  keahlianBahasaIsyarat    String   @default("")
  npwp                     String   @default("")
  namaWajibPajak           String   @default("")
  kewarganegaraan          String   @default("")
  bank                     String   @default("")
  nomorRekeningBank        String   @default("")
  rekeningAtasNama         String   @default("")
  nik                      String   @default("")
  noKK                     String   @default("")
  karpeg                   String   @default("")
  karisKarsu               String   @default("")
  lintang                  String   @default("")
  bujur                    String   @default("")
  nuks                     String   @default("")
  status                   String   @default("Aktif")
  tahunPelajaran           String   @default("2025/2026")
  semester                 String   @default("Ganjil")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([tahunPelajaran, semester])
  @@unique([no, tahunPelajaran, semester])
}

model MutasiMasuk {
  id              String   @id @default(cuid())
  nama            String
  nis             String
  asalSekolah     String
  kelas           String
  tanggalMasuk    String
  alasan          String
  noSurat         String
  statusDapodik   Boolean  @default(false)
  tahunPelajaran  String   @default("2025/2026")
  semester        String   @default("Ganjil")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TahunPelajaran {
  id              String   @id @default(cuid())
  tahunPelajaran  String   @unique
  createdAt       DateTime @default(now())

  @@index([tahunPelajaran])
}

model MutasiKeluar {
  id               String   @id @default(cuid())
  siswaId          String
  tujuanSekolah    String
  tanggalKeluar    String
  alasan           String
  noSurat          String
  statusDapodik    Boolean  @default(false)
  tahunPelajaran   String   @default("2025/2026")
  semester         String   @default("Ganjil")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  siswa            Siswa   @relation(fields: [siswaId], references: [id])

  @@index([tahunPelajaran, semester])
  @@index([siswaId])
  @@unique([siswaId, tahunPelajaran, semester])
}

model Pengaturan {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String   @default("")
  updatedAt       DateTime @updatedAt
}

// ─── Jadwal Pelajaran Models ──────────────────────────────────────────────────

model Mapel {
  id              String   @id @default(cuid())
  kode            String
  nama            String
  tahunPelajaran  String   @default("2025/2026")
  semester        String   @default("Ganjil")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([kode, tahunPelajaran, semester])
  @@index([tahunPelajaran, semester])
}

model JamPelajaran {
  id              String   @id @default(cuid())
  jamKe           Int
  jamMulai        String
  jamSelesai      String
  isIstirahat     Boolean  @default(false)
  tahunPelajaran  String   @default("2025/2026")
  semester        String   @default("Ganjil")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([jamKe, tahunPelajaran, semester])
  @@index([tahunPelajaran, semester])
}

model JadwalKelas {
  id              String   @id @default(cuid())
  hari            String
  jamKe           Int
  mapelId         String
  mapelKode       String   @default("")
  mapelNama       String   @default("")
  guruId          String   @default("")
  guruNama        String   @default("")
  rombel          String
  tahunPelajaran  String   @default("2025/2026")
  semester        String   @default("Ganjil")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([hari, jamKe, rombel, tahunPelajaran, semester])
  @@index([tahunPelajaran, semester])
  @@index([rombel])
  @@index([guruId])
  @@index([hari])
}

// ─── Absensi Models ────────────────────────────────────────────────────────

model Absensi {
  id              String   @id @default(cuid())
  siswaId         String
  siswaNama       String   @default("")
  nisn            String   @default("")
  rombel          String
  tanggal         String   // format: YYYY-MM-DD
  kodeAbsensi     String   @default("H") // H, S, I, A (configurable)
  tahunPelajaran  String   @default("2025/2026")
  semester        String   @default("Ganjil")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([siswaId, tanggal, tahunPelajaran, semester])
  @@index([tahunPelajaran, semester])
  @@index([rombel, tanggal])
  @@index([tanggal])
  @@index([siswaId])
}

model HariLibur {
  id              String   @id @default(cuid())
  tanggal         String   // format: YYYY-MM-DD
  label           String   @default("")
  kategori        String   @default("Libur Nasional") // Libur Nasional, Libur Khusus, Libur Semester, Asesmen, Lainnya
  tahunPelajaran  String   @default("2026/2027")
  createdAt       DateTime @default(now())

  @@unique([tanggal, tahunPelajaran])
  @@index([tahunPelajaran])
  @@index([tanggal])
}

model JadwalAkses {
  id              String   @id @default(cuid())
  userId          String
  rombel          String
  tahunPelajaran  String   @default("2025/2026")
  semester        String   @default("Ganjil")
  createdAt       DateTime @default(now())

  @@unique([userId, rombel, tahunPelajaran, semester])
  @@index([userId])
  @@index([tahunPelajaran, semester])
}